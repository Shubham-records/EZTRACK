        "database_schema": {
            "Gym": {
                "tablename": "Gym",
                "fields": {
                    "id": "String (UUID PK)",
                    "gymname": "String (Required)",
                    "email": "String (Unique, Required)",
                    "username": "String (Unique, Required)",
                    "password": "String (Hashed, Required)",
                    "createdAt": "DateTime (Auto)",
                    "updatedAt": "DateTime (Auto-update)"
                }
            },
            "User": {
                "tablename": "User",
                "fields": {
                    "id": "String (UUID PK)",
                    "gymId": "String (FK -> Gym.id, Required)",
                    "username": "String (Required)",
                    "password": "String (Required)",
                    "role": "String (Default: STAFF)",
                    "permissions": "ARRAY of Strings",
                    "createdAt": "DateTime",
                    "updatedAt": "DateTime"
                }
            },
            "Invoice": {
                "tablename": "Invoice",
                "fields": {
                    "id": "String (UUID PK)",
                    "gymId": "String (FK -> Gym.id, Required)",
                    "memberId": "String (FK -> Member.id, Nullable)",
                    "customerName": "String (Nullable)",
                    "invoiceDate": "DateTime (Default: now)",
                    "dueDate": "DateTime (Nullable)",
                    "items": "JSON (List of {description, quantity, rate, amount})",
                    "subTotal": "Float (Required)",
                    "tax": "Float (Default: 0)",
                    "discount": "Float (Default: 0)",
                    "total": "Float (Required)",
                    "status": "String (Default: PENDING)",
                    "paymentMode": "String (Nullable)",
                    "lastEditedBy": "String (Nullable)",
                    "editReason": "String (Nullable)",
                    "createdAt": "DateTime",
                    "updatedAt": "DateTime"
                }
            },
            "Member": {
                "tablename": "Member",
                "fields": {
                    "id": "String (UUID PK)",
                    "gymId": "String (FK -> Gym.id, Required)",
                    "Name": "String (Required)",
                    "MembershipReceiptnumber": "Integer (Nullable)",
                    "Gender": "String (Nullable)",
                    "Age": "Integer (Nullable)",
                    "AccessStatus": "String (Default: no)",
                    "height": "Float (Nullable)",
                    "weight": "Integer (Nullable)",
                    "DateOfJoining": "String (ISO Date, Nullable)",
                    "DateOfReJoin": "String (ISO Date, Nullable)",
                    "Billtype": "String (Nullable)",
                    "Address": "String (Nullable)",
                    "Whatsapp": "BigInteger (Nullable)",
                    "PlanPeriod": "String (Nullable)",
                    "PlanType": "String (Nullable)",
                    "MembershipStatus": "String (Default: Inactive)",
                    "MembershipExpiryDate": "String (Nullable)",
                    "LastPaymentDate": "String (Nullable)",
                    "NextDuedate": "String (Nullable)",
                    "LastPaymentAmount": "Integer (Nullable)",
                    "RenewalReceiptNumber": "Integer (Nullable)",
                    "Aadhaar": "BigInteger (Nullable)",
                    "Remark": "String (Nullable)",
                    "Mobile": "BigInteger (Nullable)",
                    "extraDays": "String (Nullable)",
                    "agreeTerms": "Boolean (Default: False)",
                    "lastEditedBy": "String (Nullable)",
                    "editReason": "String (Nullable)",
                    "createdAt": "DateTime",
                    "updatedAt": "DateTime"
                }
            },
            "ProteinStock": {
                "tablename": "ProteinStock",
                "fields": {
                    "id": "String (UUID PK)",
                    "gymId": "String (FK -> Gym.id, Required)",
                    "Year": "String (Nullable)",
                    "Month": "String (Nullable)",
                    "Brand": "String (Nullable)",
                    "ProductName": "String (Nullable)",
                    "Flavour": "String (Nullable)",
                    "Weight": "String (Nullable)",
                    "Quantity": "String (Nullable)",
                    "MRPPrice": "String (Nullable)",
                    "LandingPrice": "String (Nullable)",
                    "TotalPrice": "String (Nullable)",
                    "Remark": "String (Nullable)",
                    "createdAt": "DateTime",
                    "updatedAt": "DateTime"
                }
            }
        }
    },
