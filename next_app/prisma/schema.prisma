// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gym {
  id        String   @id @default(uuid())
  gymname   String
  email     String   @unique
  username  String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            Member[]
  proteinStocks      ProteinStock[]
  membershipReturns  MembershipReturn[]
  perDayAdmissions   PerDayAdmission[]
}

model Member {
  id                      String   @id @default(uuid())
  gymId                   String
  gym                     Gym      @relation(fields: [gymId], references: [id])
  
  Name                    String
  MembershipReceiptnumber Int?
  Gender                  String?
  Age                     Int?
  AccessStatus            String?  @default("no")
  height                  Float?
  weight                  Int?
  DateOfJoining           String?  // Keeping as String YYYY-MM-DD to match frontend/legacy
  DateOfReJoin            String?
  Billtype                String?
  Address                 String?
  Whatsapp                BigInt?     // Using BigInt for phone numbers if they are large, or String
  PlanPeriod              String?
  PlanType                String?
  MembershipStatus        String?  @default("Inactive")
  MembershipExpiryDate    String?
  LastPaymentDate         String?
  NextDuedate             String?
  LastPaymentAmount       Int?
  RenewalReceiptNumber    Int?
  Aadhaar                 BigInt?
  Remark                  String?
  Mobile                  BigInt?
  extraDays               String?  // Frontend sends as string '0' usually
  agreeTerms              Boolean? @default(false)
  
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())

  @@index([gymId])
}

model ProteinStock {
  id                  String   @id @default(uuid())
  gymId               String
  gym                 Gym      @relation(fields: [gymId], references: [id])

  Year                String?
  Month               String?
  Brand               String?
  ProductName         String?
  Flavour             String?
  Weight              String?
  Quantity            String? // Can be Int, but legacy seems to treat loosely
  MRPPrice            String? // Mapped from 'MRP Price(1 pcs)'
  LandingPrice        String? // Mapped from 'Landing price(1 pcs)'
  TotalPrice          String? // Mapped from 'Total price'
  Remark              String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

   @@index([gymId])
}

model MembershipReturn {
  id                      String   @id @default(uuid())
  gymId                   String
  gym                     Gym      @relation(fields: [gymId], references: [id])

  MembershipReceiptnumber Int?
  ReturnDate              String?
  RemainingDays           Int?
  RefundAmount            Int?
  Reason                  String?

  createdAt               DateTime @default(now())

   @@index([gymId])
}

model PerDayAdmission {
  id          String   @id @default(uuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])

  Name        String?
  Gender      String?
  Age         Int?
  PlanType    String?
  Days        Int?
  StartDate   String?
  EndDate     String?
  Amount      Int?
  weight      Int?
  height      Float?
  Mobile      BigInt?
  Whatsapp    BigInt?
  Aadhaar     BigInt?

  createdAt   DateTime @default(now())

   @@index([gymId])
}
